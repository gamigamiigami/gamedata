rules_version = '2';

// ============================================================================
// IOgames Firestore セキュリティルール
// ----------------------------------------------------------------------------
// 方針:
//   1. 既存の機能（グローバルランキング ranks〇〇 / 違反ログ violations）は
//      現状の動作をそのまま維持する（生徒は匿名でスコアを書き込むため）。
//   2. 新しく追加する学校系コレクションだけを厳しくロックする。
//      とくに school_private（先生のメールアドレス等）は管理者しか読み書き不可。
//
// 使い方（詳細は firebase/SETUP.md）:
//   下の  PASTE_ADMIN_UID_HERE  を、Firebase Console で作成した管理者アカウントの
//   ユーザーUID に置き換えてから、このファイル全体を Console の
//   「Firestore Database → ルール」に貼り付けて「公開」してください。
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者かどうか（Firebase Authentication でログインした管理者UIDと一致するか）
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'PASTE_ADMIN_UID_HERE';
    }

    // ------------------------------------------------------------------
    // 既存：グローバルランキング（ranks〇〇 / ranks〇〇_nobonus）
    //   ゲームタイトルごとにコレクションが作られるためワイルドカードで一致。
    //   現状どおり全員が読み書き可能（匿名スコア投稿・表示・リセット）。
    //   ※ このルールは col 名が 'ranks' で始まる場合だけ許可するので、
    //     学校系コレクション（schools / school_private 等）には一切影響しない。
    // ------------------------------------------------------------------
    match /{rankCol}/{doc} {
      allow read, write: if rankCol.matches('ranks.*');
    }

    // ------------------------------------------------------------------
    // 既存：違反ログ（禁止ワード使用の記録）
    //   作成は全員（クライアントが記録）、閲覧・削除は管理者のみ。
    // ------------------------------------------------------------------
    match /violations/{doc} {
      allow create: if true;
      allow read, delete, update: if isAdmin();
    }

    // ------------------------------------------------------------------
    // 新規：学校申請（先生が登録フォームから送信）
    //   作成は誰でも可。ただし第三者は内容を読めない（read は管理者のみ）。
    //   → 登録ログを第三者が閲覧することは不可能。
    // ------------------------------------------------------------------
    match /school_applications/{appId} {
      allow create: if request.resource.data.keys().hasAll(['schoolName', 'email', 'status'])
                    && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // 新規：学校の公開情報（学校名・都道府県など。メールは含めない）
    //   全員 read（学校コードでログインした生徒が学校名を表示するため）。
    //   書き込みは管理者のみ。
    // ------------------------------------------------------------------
    match /schools/{schoolCode} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // 新規：学校の非公開情報（先生のメールアドレス等）
    //   読み書きとも管理者のみ。第三者・生徒からは一切アクセス不可。
    // ------------------------------------------------------------------
    match /school_private/{schoolCode} {
      allow read, write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // 新規：学校内ランキング（学校コードでログイン中の生徒のスコア）
    //   学校コードを知っている人だけが書き込み・閲覧（read, create）。
    //   改ざん・一括削除は管理者のみ。
    // ------------------------------------------------------------------
    match /school_scores/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['schoolCode', 'game', 'score']);
      allow update, delete: if isAdmin();
    }
  }
}
